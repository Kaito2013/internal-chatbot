# =====================================================================
# Internal Chatbot - Environment Variables Template
# Copy this file to .env and fill in your values
# =====================================================================

# =====================================================================
# LLM Provider Configuration
# =====================================================================
# Options: openai | minimax | anthropic | deepseek | mock
LLM_PROVIDER=minimax

# LLM Model name (depends on provider)
# Minimax: MiniMax-Text-01, abab6.5s-chat, etc.
# OpenAI: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# DeepSeek: deepseek-chat, deepseek-coder
LLM_MODEL=abab6.5s-chat

# LLM Parameters
LLM_TEMPERATURE=0.1
MAX_TOKENS=1000

# =====================================================================
# Minimax Configuration (OpenAI-compatible)
# =====================================================================
# Get your API key from: https://platform.minimax.chat/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_GROUP_ID=your_group_id_here

# =====================================================================
# OpenAI (alternative to Minimax)
# =====================================================================
OPENAI_API_KEY=sk-your_openai_key

# =====================================================================
# DeepSeek (alternative)
# =====================================================================
DEEPSEEK_API_KEY=sk-your_deepseek_key

# =====================================================================
# Anthropic Claude (alternative)
# =====================================================================
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# =====================================================================
# Embedding Configuration
# =====================================================================
# OpenAI embedding model
OPENAI_API_KEY=sk-your_key_for_embeddings_too
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# =====================================================================
# Vector Database (Qdrant)
# =====================================================================
VECTOR_DB_TYPE=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents

# =====================================================================
# RAG Settings
# =====================================================================
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# =====================================================================
# CRM Integration (optional)
# =====================================================================
CRM_PROVIDER=generic
CRM_API_URL=https://your-crm.com/api
CRM_API_KEY=your_crm_api_key
CRM_USE_MOCK=true

# =====================================================================
# Backend Server
# =====================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=*
